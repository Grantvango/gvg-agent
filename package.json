{
	"name": "appsec-dinosaur",
	"displayName": "AppSec Dinosaur",
	"description": "A simple AppSec extension",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.109.0"
	},
	"categories": [
		"Other"
	],
	"icon": "assets/dinosaur.png",
	"activationEvents": [
		"onView:appsec-dinosaur-view",
		"onCommand:appsec-dinosaur.runScan"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "appsec-dinosaur.runScan",
				"title": "Run Scan",
				"category": "AppSec Dinosaur"
			},
			{
				"command": "appsec-dinosaur.openFile",
				"title": "Open File",
				"category": "AppSec Dinosaur"
			},
			{
				"command": "appsec-dinosaur.fixFinding",
				"title": "Fix Finding",
				"category": "AppSec Dinosaur",
				"icon": "$(check)"
			},
			{
				"command": "appsec-dinosaur.ignoreFinding",
				"title": "Ignore Finding",
				"category": "AppSec Dinosaur",
				"icon": "$(circle-slash)"
			},
			{
				"command": "appsec-dinosaur.applyContextScore",
				"title": "Apply Business Context Score",
				"category": "AppSec Dinosaur"
			}
		],
		"menus": {
			"view/item/context": [
				{
					"command": "appsec-dinosaur.fixFinding",
					"when": "viewItem == finding",
					"group": "inline@1"
				},
				{
					"command": "appsec-dinosaur.ignoreFinding",
					"when": "viewItem == finding",
					"group": "inline@2"
				},
				{
					"command": "appsec-dinosaur.applyContextScore",
					"when": "viewItem =~ /^finding-(critical|high)/",
					"group": "1_modification"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "appsec-dinosaur-sidebar",
					"title": "AppSec Dinosaur",
					"icon": "assets/dinosaur.png"
				}
			]
		},
		"views": {
			"appsec-dinosaur-sidebar": [
				{
					"id": "appsec-dinosaur-view",
					"name": "Scan Controls"
				},
				{
					"id": "appsec-dinosaur-findings",
					"name": "Findings",
					"when": "false"
				},
				{
					"id": "appsec-dinosaur-settings",
					"name": "Settings"
				},
				{
					"id": "appsec-dinosaur-dashboard",
					"name": "Dashboard",
					"type": "webview"
				}
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/vscode": "^1.109.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"typescript-eslint": "^8.56.1",
		"eslint": "^9.39.3",
		"typescript": "^5.9.3",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2"
	}
}
